# Copy to .env.local to enable the optional live backends. All are OPTIONAL — with none set,
# the dashboard runs fully on the bundled datasets in public/data/.

# Live data pull (Metabase). When set, "Get Data" POSTs to {URL}/api/get_data instead of
# reading bundled .xlsx. See README "Environment variables & the backend seam".
# VITE_DATA_API_URL=https://your-backend.example.com

# Lazy SOR enrichment. When set, the SOR Hints / Master SOR Record tabs fetch per-document
# from {URL}/api/sor/lookup for docs that arrived without SOR.
# VITE_SOR_API_URL=https://your-backend.example.com

# Email Sender backend (Flask + Gmail SMTP). Defaults to http://localhost:5001.
# VITE_EMAIL_BACKEND_URL=http://localhost:5001
