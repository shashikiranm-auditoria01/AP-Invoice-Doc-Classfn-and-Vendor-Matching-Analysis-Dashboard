# ── Dependencies & build output (path-agnostic so nesting doesn't matter) ──
**/node_modules/
**/dist/
**/.vite/

# ── Python ──
**/__pycache__/
*.pyc
.venv/
venv/

# ── OS / editor ──
.DS_Store
*.log
Thumbs.db
.idea/
.vscode/

# ── Scratch / test artifacts ──
_e2e_*.mjs
*.tmp

# ── Data & local env ──
# .xlsx are ignored everywhere so real tenant/customer data is never committed.
*.xlsx
# The committed data-fetching .env is an EMPTY template. Any OTHER .env stays local:
**/.env.local
**/dashboard/.env
